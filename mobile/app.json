{
  "expo": {
    "name": "Quito Ubicacion Segura",
    "slug": "quito-ubicacion-segura",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "quito-segura",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020617"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {}
    }
  }
}
