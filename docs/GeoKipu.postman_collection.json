    {
      "name": "Users",
      "item": [
        {
          "name": "POST Crear usuario",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString().slice(-8);",
                  "const firstNine = `171${suffix.padStart(6, '0').slice(-6)}`;",
                  "const coefficients = [2,1,2,1,2,1,2,1,2];",
                  "const sum = firstNine.split('').reduce((total, digit, index) => {",
                  "  let value = Number(digit) * coefficients[index];",
                  "  if (value >= 10) value -= 9;",
                  "  return total + value;",
                  "}, 0);",
                  "const verifier = sum % 10 === 0 ? 0 : 10 - (sum % 10);",
                  "const newUserEmail = `postman.${suffix}@geokipu.com`;",
                  "const newUserPhone = `09${suffix}`;",
                  "const newUserCedula = `${firstNine}${verifier}`;",
                  "pm.variables.set('newUserEmail', newUserEmail);",
                  "pm.variables.set('newUserPhone', newUserPhone);",
                  "pm.variables.set('newUserCedula', newUserCedula);",
                  "pm.environment.set('newUserEmail', newUserEmail);",
                  "pm.environment.set('newUserPhone', newUserPhone);",
                  "pm.environment.set('newUserCedula', newUserCedula);",
                  "pm.collectionVariables.set('newUserEmail', newUserEmail);",
                  "pm.collectionVariables.set('newUserPhone', newUserPhone);",
                  "pm.collectionVariables.set('newUserCedula', newUserCedula);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Crear usuario 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const json = pm.response.json();",
                  "pm.environment.set('userId', json.user.id);",
                  "pm.collectionVariables.set('userId', json.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Usuario Postman Local\",\n  \"email\": \"{{newUserEmail}}\",\n  \"password\": \"Postman123\",\n  \"language\": \"es\",\n  \"cedula\": \"{{newUserCedula}}\",\n  \"phone\": \"{{newUserPhone}}\",\n  \"role\": \"persona\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
